# ==========================================
# BEKENYA.COM — Environment Variables
# ==========================================
# Copy this file to .env.local and fill in values

# --- App ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl

# --- Database (Neon PostgreSQL recommended) ---
DATABASE_URL=postgresql://user:password@host/bekenya

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- M-Pesa (Safaricom Daraja API) ---
# Get credentials at: https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_BUSINESS_SHORT_CODE=174379
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback
# Set to 'sandbox' or 'production'
MPESA_ENVIRONMENT=sandbox

# --- Stripe (Global Payments) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Flutterwave (Africa-wide) ---
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=

# --- AI (Claude) ---
ANTHROPIC_API_KEY=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- SMS/WhatsApp (Africa's Talking) ---
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox

# --- File Storage (Cloudflare R2) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=bekenya-uploads
