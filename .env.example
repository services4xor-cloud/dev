# ==========================================
# Be[X] v2 — Environment Variables
# ==========================================
# Copy this file to .env.local and fill in values

# --- Auth (required) ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Database (required) ---
DATABASE_URL=

# --- Email (required for magic link) ---
RESEND_API_KEY=
EMAIL_FROM=BeNetwork <onboarding@resend.dev>

# --- Map (required for map tiles) ---
NEXT_PUBLIC_MAPTILER_KEY=

# --- AI Agent (required for chat) ---
ANTHROPIC_API_KEY=

# --- AI Fallback + Translation (optional) ---
GOOGLE_GEMINI_API_KEY=
DEEPL_API_KEY=

# --- Country deployment ---
NEXT_PUBLIC_COUNTRY_CODE=KE
