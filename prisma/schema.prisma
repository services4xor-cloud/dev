// Be[Country] Platform — Database Schema
// PostgreSQL with Prisma ORM
//
// Vocabulary: Pioneer (person), Anchor (org), Path (opportunity),
//             Chapter (engagement), Venture (experience + path)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ───────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  phone         String?   // Kenyan format: 2547XXXXXXXX
  role          UserRole  @default(PIONEER)
  avatarUrl     String?
  country       String    @default("KE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  profile       Profile?
  postedPaths   Path[]        // Anchors post Paths
  chapters      Chapter[]     // Pioneers open Chapters
  payments      Payment[]
  referrals     Referral[]  @relation("ReferredBy")
  referred      Referral?   @relation("Referred")
}

enum UserRole {
  PIONEER
  ANCHOR
  ADMIN
}

// ─── Profile ─────────────────────────────────────────────────────────────────

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id])
  headline    String?
  bio         String?
  resumeUrl   String?
  skills      String[] // Array of skill tags
  experience  Int?     // Years of experience
  location    String?
  linkedinUrl String?
  videoUrl    String?  // 30-second pitch video
  isPublic    Boolean  @default(true)
  updatedAt   DateTime @updatedAt
}

// ─── Paths ───────────────────────────────────────────────────────────────────

model Path {
  id           String      @id @default(cuid())
  anchorId     String
  anchor       User        @relation(fields: [anchorId], references: [id])
  title        String
  company      String
  description  String
  location     String
  isRemote     Boolean     @default(false)
  pathType     PathType    @default(FULL_PATH)
  salaryMin    Int?
  salaryMax    Int?
  currency     String      @default("KES")
  skills       String[]
  country      String      @default("KE")
  status       PathStatus  @default(OPEN)
  tier         PathTier    @default(BASIC)
  expiresAt    DateTime
  createdAt    DateTime    @default(now())

  chapters     Chapter[]
  payments     Payment[]
}

enum PathType {
  FULL_PATH
  PART_PATH
  SEASONAL
  CONTRACT
  REMOTE
}

enum PathStatus {
  DRAFT
  OPEN
  PAUSED
  EXPIRED
  FILLED
}

enum PathTier {
  BASIC
  FEATURED
  PREMIUM
}

// ─── Chapters ────────────────────────────────────────────────────────────────
// A Chapter is a Pioneer's engagement with a Path.

model Chapter {
  id          String        @id @default(cuid())
  pathId      String
  path        Path          @relation(fields: [pathId], references: [id])
  pioneerId   String
  pioneer     User          @relation(fields: [pioneerId], references: [id])
  coverLetter String?
  status      ChapterStatus @default(PENDING)
  openedAt    DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

enum ChapterStatus {
  PENDING
  REVIEWED
  SHORTLISTED
  DECLINED
  PLACED
}

// ─── Payments ─────────────────────────────────────────────────────────────────

model Payment {
  id                 String        @id @default(cuid())
  userId             String
  user               User          @relation(fields: [userId], references: [id])
  pathId             String?
  path               Path?         @relation(fields: [pathId], references: [id])
  amount             Int           // In smallest currency unit (KES cents or USD cents)
  currency           String        @default("KES")
  method             PaymentMethod
  status             PaymentStatus @default(PENDING)
  // M-Pesa specific
  mpesaReceiptNumber String?
  checkoutRequestId  String?
  // Stripe specific
  stripePaymentId    String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

enum PaymentMethod {
  MPESA
  STRIPE
  FLUTTERWAVE
  PAYPAL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
  REFUNDED
}

// ─── Referrals ────────────────────────────────────────────────────────────────

model Referral {
  id           String   @id @default(cuid())
  referredById String
  referredBy   User     @relation("ReferredBy", fields: [referredById], references: [id])
  referredId   String   @unique
  referred     User     @relation("Referred", fields: [referredId], references: [id])
  bonusPaid    Boolean  @default(false)
  bonusAmount  Int?     // KES amount
  createdAt    DateTime @default(now())
}

// ─── Social Media Posts ───────────────────────────────────────────────────────

model SocialPost {
  id           String   @id @default(cuid())
  type         String   // 'new_path' | 'safari_package' | 'pioneer_success' | 'charity_update'
  title        String
  body         String   @db.Text
  imageUrl     String?
  link         String?
  platforms    String   // JSON array of platform names
  scheduledFor DateTime?
  postedAt     DateTime?
  status       String   @default("draft") // 'draft' | 'scheduled' | 'posted' | 'failed'
  countryCode  String   @default("KE")
  results      String?  @db.Text // JSON results per platform
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([countryCode])
  @@index([scheduledFor])
}
